# Copie ce fichier en .env puis remplis les vraies valeurs :
#   cp .env.example .env
# Ne commit JAMAIS le fichier .env lui-même (déjà dans .gitignore).

# Port du serveur (Render le définit automatiquement, inutile de le fixer là-bas)
PORT=3000

# Secret utilisé pour signer les sessions (JWT). Génère-en un avec :
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=d949cfa764f08b71f93cf06165f487179eb7f39ba638474bf48f309c2cc9af0472b8ed81fdf47844fd6b1a2ee7a938e2

# Clé API Mistral — reste côté serveur, jamais exposée au navigateur
MISTRAL_API_KEY=2DfNxT3bmLV1HdNub9bnoMjX3PKvR1dC
MISTRAL_MODEL=mistral-large-latest

# Modèle utilisé automatiquement quand une image (photo caméra/galerie) est envoyée dans le chat
MISTRAL_VISION_MODEL=pixtral-large-latest

# Modèle utilisé quand l'utilisateur choisit "Rapide" ou "Code" dans Paramètres > Modèle
MISTRAL_FAST_MODEL=mistral-small-latest
MISTRAL_CODE_MODEL=codestral-latest

# Optionnel — active la recherche web en direct (bouton 🛠️ Outils dans le chat).
# Clé gratuite sur https://tavily.com. Si vide, la recherche web reste indisponible.
TAVILY_API_KEY=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

# Optionnel — calculs et données précises (maths, conversions, sciences).
# Clé gratuite (compte développeur) sur https://developer.wolframalpha.com
WOLFRAM_APP_ID=4W4PEVVWK7

# Optionnel — météo en direct par ville. Clé gratuite sur https://openweathermap.org/api
OPENWEATHER_API_KEY=38b53eff71398af6cf9e24fcd5e0575f

# Optionnel — si renseigné, le mode "Rapide" (Paramètres > Modèle) utilise Groq
# au lieu de Mistral Small : réponses nettement plus rapides. Clé gratuite sur
# https://console.groq.com. Si vide, "Rapide" reste sur Mistral Small.
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile

NODE_ENV=development
